# =============================================================================
# Composio 集成中间件 — 环境变量模板
# =============================================================================
# 本文件为 .env.example 占位模板，用于记录 Composio 集成所需的全部环境变量。
# 当前状态：⚠️ 阻塞中 — 等待 CY 授权注册 Composio 账号后填充真实值。
# 不可直接复制为 .env 使用，所有真实密钥须经 Hermes credentials 纳管。
# =============================================================================

# ---------------------------------------------------------------------------
# 必填：Composio API Key
# ---------------------------------------------------------------------------
# 来源：Composio Dashboard (https://app.composio.dev) → Settings → API Keys
# 类型：Bearer token，格式类似 "composio_xxxx_xxxxxxxxxxxxxxxx"
# 状态：🔴 缺失 — 需 CY 注册 Free tier 账号后生成
# COMPOSIO_API_KEY=composio_xxxx_xxxxxxxxxxxxxxxxxxxx
# 当前状态：未授权，值为空表示等待 CY 注册后填充
COMPOSIO_API_KEY=

# ---------------------------------------------------------------------------
# 必填：Composio 默认用户 ID
# ---------------------------------------------------------------------------
# Composio 内部用户标识，用于 OAuth 连接管理
# 状态：🔴 缺失 — 注册账号后自动生成
# COMPOSIO_USER_ID=user_xxxx_xxxxxxxxxxxx
# 当前状态：未授权
COMPOSIO_USER_ID=

# ---------------------------------------------------------------------------
# 选填：平台 OAuth 连接 ID（可注册多个）
# ---------------------------------------------------------------------------
# 每连接一个外部平台后，Composio 会生成一个 connection ID。
# 格式示例：gmail_connection_id="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# 状态：🔴 缺失 — 需 CY 授权并完成 OAuth 授权后自动生成
# COMPOSIO_CONNECTION_GMAIL=
# COMPOSIO_CONNECTION_GITHUB=
# COMPOSIO_CONNECTION_NOTION=
# COMPOSIO_CONNECTION_GOOGLECALENDAR=

# ---------------------------------------------------------------------------
# 选填：Chunk 参数
# ---------------------------------------------------------------------------
# COMPOSIO_CHUNK_MAX_TOKENS=3000
# COMPOSIO_CHUNK_OVERLAP_TOKENS=200

# ---------------------------------------------------------------------------
# 选填：Qdrant VDB 写入目标
# ---------------------------------------------------------------------------
# COMPOSIO_VDB_NAMESPACE=ns_global_knowledge
# COMPOSIO_VDB_FALLBACK_NAMESPACE=ns_resources

# ---------------------------------------------------------------------------
# 选填：调度频率（Hermes cron 表达式）
# ---------------------------------------------------------------------------
# COMPOSIO_CRON_GMAIL=*/20 * * * *
# COMPOSIO_CRON_GITHUB=0 * * * *
# COMPOSIO_CRON_NOTION=0 * * * *
# COMPOSIO_CRON_CALENDAR=0 * * * *
